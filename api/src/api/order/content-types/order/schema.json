{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "orderId": {
      "type": "string"
    },
    "createAt": {
      "type": "datetime"
    },
    "totalPrice": {
      "type": "decimal"
    },
    "userEmail": {
      "type": "string"
    },
    "statusOrder": {
      "type": "enumeration",
      "enum": [
        "waiting",
        "accepted",
        "declined"
      ]
    },
    "shippingAdress": {
      "type": "string"
    },
    "order_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order-item.order-item",
      "mappedBy": "order"
    },
    "paymentMethod": {
      "type": "enumeration",
      "enum": [
        "PayPal",
        "BLIK",
        "Credic Card",
        "Cash on delivery"
      ]
    },
    "notes": {
      "type": "text"
    },
    "discount": {
      "type": "decimal"
    }
  }
}
