{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": {
    "singularName": "review",
    "pluralName": "reviews",
    "displayName": "reviews"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "rating": {
      "type": "decimal"
    },
    "comment": {
      "type": "text"
    },
    "authorName": {
      "type": "string"
    },
    "commentCreatedAt": {
      "type": "datetime"
    },
    "approved": {
      "type": "boolean"
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "reviews"
    }
  }
}
